# ==================================
# INTERNAL - Mavin Intelligence Platform
# Environment Variables
# Copy this file to .env and fill in real values.
# ==================================

# Application
NODE_ENV=development
APP_NAME=INTERNAL
VITE_API_BASE_URL=/api
VITE_SPOTIFY_PROXY_URL=/api
VITE_CHARTMETRIC_PROXY_URL=/api

# ==================================
# Cohere AI
# Used for AI assistant, insights, analysis
# ==================================
COHERE_API_KEY=

# ==================================
# Chartmetric API
# Used for artist analytics, streams,
# releases, playlists, audience data
# ==================================
CHARTMETRIC_REFRESH_TOKEN=
CHARTMETRIC_API_URL=https://api.chartmetric.com/api
APIFY_CHARTMETRIC_TOKEN=
VITE_CHARTMETRIC_REFRESH_TOKEN=
VITE_CHARTMETRIC_API_URL=https://api.chartmetric.com/api

# ==================================
# XPOZ API
# Used for social listening:
# TikTok, Instagram, X/Twitter monitoring
# ==================================
XPOZ_API_KEY=

# ==================================
# Database
# ==================================
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_REST_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=
# Example: DATABASE_URL=postgresql://user:password@host:5432/internal

# ==================================
# Authentication
# ==================================
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ==================================
# Storage
# For release decks, campaign files,
# images, PDFs, videos
# ==================================
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ==================================
# AI Search / Internet Research
# ==================================
SEARCH_API_KEY=

# ==================================
# Analytics
# ==================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================================
# Spotify API
# ==================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify
